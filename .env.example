PORT=4000
AGENT_BASE_URL=http://localhost:4000

# TRON testnet defaults. Nile is recommended for this demo.
TRON_NETWORK=nile
TRON_FULL_HOST=https://nile.trongrid.io

# Optional, but useful when using TronGrid endpoints.
TRON_PRO_API_KEY=

# Do not put private keys in this file.
# Configure a local encrypted Agent Wallet instead:
#   npx agent-wallet start local_secure --wallet-id tron-demo
