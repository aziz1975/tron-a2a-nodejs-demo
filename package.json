{
  "name": "tron-a2a-nodejs-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A TRON testnet operations agent exposed over the A2A protocol.",
  "scripts": {
    "build": "tsc --noEmit",
    "server": "tsx src/server.ts",
    "client": "tsx src/client.ts",
    "client:stream": "tsx src/client.ts --stream",
    "probe": "tsx src/probe.ts"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@bankofai/agent-wallet": "^2.4.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "tronweb": "^6.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "axios": "^1.16.0"
  },
  "engines": {
    "node": ">=22"
  }
}
